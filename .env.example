# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Optional redirect behavior
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Supabase (optional for basic sign-in/sign-up UI, required for profile sync)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stream (messages feed integration)
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_API_SECRET=
STREAM_FEED_GROUP=timeline
STREAM_FEED_ID=global

# CDN + edge cache
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_CDN_HOST=
NEXT_PUBLIC_MEDIA_CDN_HOST=

# Redis REST cache/queue (optional)
REDIS_REST_URL=
REDIS_REST_TOKEN=
